#!/bin/sh
# Pre-commit hook: detecta posibles secretos o archivos sensibles antes de commitear

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

# Archivos que nunca deben commitearse
FORBIDDEN_FILES=(".env" "*.pem" "*.key" "*.p12" "*.pfx" "id_rsa" "id_ed25519" "credentials.json" "secrets.json")

for pattern in "${FORBIDDEN_FILES[@]}"; do
  matches=$(git diff --cached --name-only | grep -iE "$pattern" 2>/dev/null)
  if [ -n "$matches" ]; then
    echo "${RED}[SECURITY] Archivo sensible detectado: $matches${NC}"
    ERRORS=$((ERRORS + 1))
  fi
done

# Patrones de secretos en el contenido
SECRET_PATTERNS=(
  "password\s*=\s*['\"][^'\"]{4,}"
  "api_key\s*=\s*['\"][^'\"]{8,}"
  "secret\s*=\s*['\"][^'\"]{8,}"
  "token\s*=\s*['\"][^'\"]{8,}"
  "AWS_SECRET"
  "PRIVATE KEY"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(py|js|ts|json|yml|yaml|env|cfg|ini|conf)$")

for file in $STAGED_FILES; do
  for pattern in "${SECRET_PATTERNS[@]}"; do
    if git show ":$file" | grep -iqE "$pattern" 2>/dev/null; then
      echo "${YELLOW}[WARNING] Posible secreto en '$file' (patron: $pattern)${NC}"
      echo "  Verifica el archivo antes de continuar."
      ERRORS=$((ERRORS + 1))
    fi
  done
done

if [ $ERRORS -gt 0 ]; then
  echo ""
  echo "${RED}Commit bloqueado: $ERRORS problema(s) detectado(s).${NC}"
  echo "Si es un falso positivo, usa: git commit --no-verify"
  exit 1
fi

exit 0
